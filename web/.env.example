NEXT_PUBLIC_SITE_URL=https://platformer-inky.vercel.app
NEXT_PUBLIC_CHAIN_ID=8453

# Deployed Foundry CheckIn contract on Base mainnet
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=0x054650F48918c55D2DAD41dE221c6e34FBfBCa24

# Base dashboard app id (<meta name="base:app_id" /> — domain verification)
NEXT_PUBLIC_BASE_APP_ID=6a02cecaf8601f8d21fe6b38

# Builder code string from base.dev (bc_…). Optional raw hex override instead of ox encoding:
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=0x...

NEXT_PUBLIC_BUILDER_CODE=bc_replace_me

# Optional readable app name for Coinbase connector
NEXT_PUBLIC_SITE_NAME=Neon Flux Relay

# Optional WalletConnect (Reown); omit to hide that connector
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
